{
  "applications": {
    "ConferenceBooking.HttpApi.Host": {
      "type": "dotnet-project",
      "launchUrl": "https://localhost:44363",
      "path": "../../../src/ConferenceBooking.HttpApi.Host/ConferenceBooking.HttpApi.Host.csproj",
      "kubernetesService": ".*-httpapihost$",
      "healthCheckEndpoint": "/health-status",
      "healthUiEndpoint": "/health-ui",
      "execution": {
        "order": 4
      }
    },
    "ConferenceBooking.Blazor": {
      "type": "dotnet-project",
      "launchUrl": "https://localhost:44382",
      "path": "../../../src/ConferenceBooking.Blazor/ConferenceBooking.Blazor.csproj",
      "healthCheckEndpoint": "/",
      "kubernetesService": ".*-blazor$",
      "execution": {
        "order": 2
      }
    }
  },
  "containers": {
    "serviceName": "ConferenceBooking-Containers",
  },
  "tasks":{
    "Initialize Solution":{
      "behaviour": 2,
      "startCommand": "./initialize-solution.ps1",
      "workingDirectory": "../../scripts",
      "shortDescription": "Installs required UI libraries, creates required certificates and seeds the database."
    },
    "Migrate Database":{
      "behaviour": 0,
      "startCommand": "./migrate-database.ps1",
      "workingDirectory": "../../scripts",
      "shortDescription": "Migrates the database to the latest version."
    }
  }
}